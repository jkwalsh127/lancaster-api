{
  "name": "de-dash-api",
  "version": "1.0.0",
  "description": "DE api server",
  "repository": {
    "type": "git",
    "url": "https://github.com/jkwalsh127/de-dash-api"
  },
  "scripts": {
    "start": "NODE_ENV=production pm2 start server.js",
    "dev": "NODE_ENV=development nodemon server.js",
    "fresh": "npm run clean && npm run seed",
    "clean": "node clean.js",
    "format": "prettier --write --config .prettierrc.json \"**/*.js\"",
    "lint": "eslint --fix --config .eslintrc.json \"**/*.js\"",
    "remark": "remark . -o"
  },
  "dependencies": {
    "aws-sdk": "^2.1641.0",
    "axios": "^1.6.5",
    "bcrypt": "^5.1.0",
    "bcryptjs": "^2.4.3",
    "bree": "^9.2.2",
    "cabin": "^13.2.5",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "dotenv-safe": "^8.2.0",
    "ejs": "^3.1.8",
    "express": "^4.17.1",
    "express-validator": "^6.2.0",
    "helmet": "^3.21.2",
    "moment": "^2.29.4",
    "mongoose": "^6.7.2",
    "mongoose-paginate-v2": "^1.3.3",
    "nanoid": "^3.0.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "trim-request": "^1.0.6",
    "validator": "^13.7.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.20"
  }
}
